{
  "name": "saleboom_seo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently --names \"nextjs,worker\" --prefix-colors \"cyan,yellow\" \"npm run dev:nextjs\" \"npm run dev:worker\"",
    "dev:nextjs": "mkdir -p logs && next dev 2>&1 | tee logs/nextjs.log",
    "dev:worker": "mkdir -p logs && npx tsx --env-file=.env.local workers/index.ts 2>&1 | tee logs/worker.log",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d"
  },
  "dependencies": {
    "@ai-sdk/azure": "^4.0.2",
    "@auth/core": "^0.41.2",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@azure/storage-blob": "^12.33.0",
    "@azure/storage-queue": "^12.31.0",
    "@gsap/react": "^2.1.2",
    "@mendable/firecrawl-js": "^4.28.3",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@types/bcryptjs": "^2.4.6",
    "ai": "^7.0.4",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "node-html-parser": "^8.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.16.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^4.0.1",
    "@aws-sdk/client-sqs": "^3.1075.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "ollama-ai-provider": "^1.2.0",
    "prettier": "^3.8.5",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
