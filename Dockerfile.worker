FROM node:20-alpine
WORKDIR /app

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 worker

COPY package*.json ./
# Install all deps including devDependencies (tsx is a devDep)
RUN npm ci

COPY --chown=worker:nodejs . .

ENV NODE_ENV=production
USER worker
CMD ["./node_modules/.bin/tsx", "workers/index.ts"]
