# Copy to secrets.yaml, fill in values, then run seal.sh.
# Never commit secrets.yaml — only sealed-secret.yaml is safe to commit.
apiVersion: v1
kind: Secret
metadata:
  name: saleboomseo-secrets
  namespace: saleboomseo
type: Opaque
stringData:
  # ── Adapters ──────────────────────────────────────────────
  QUEUE_PROVIDER: "bullmq"
  STORAGE_PROVIDER: "local"
  AUTH_PROVIDER: "authjs"
  CRAWL_PROVIDER: "firecrawl"
  LOG_PROVIDER: "pino"
  AI_PROVIDER: "groq"            # or: google

  # ── App ───────────────────────────────────────────────────
  NEXT_PUBLIC_APP_URL: "https://saleboomseo.dpdns.org"
  AUTH_SECRET: ""                # openssl rand -base64 32
  PASSWORD_PEPPER: ""            # openssl rand -base64 32

  # ── Database ──────────────────────────────────────────────
  DATABASE_URL: "postgresql://postgres:<password>@postgres.saleboomseo.svc.cluster.local:5432/saleboomseo"
  POSTGRES_PASSWORD: ""          # used by postgres pod and DATABASE_URL above

  # ── Redis (BullMQ) ────────────────────────────────────────
  REDIS_URL: "redis://redis.saleboomseo.svc.cluster.local:6379"

  # ── Firecrawl (self-hosted) ───────────────────────────────
  FIRECRAWL_API_URL: "https://api.firecrawl.dev"
  FIRECRAWL_API_KEY: ""          # your Firecrawl cloud API key
  FIRECRAWL_TIMEOUT_MS: "30000"

  # ── AI ────────────────────────────────────────────────────
  GROQ_API_KEY: ""               # if AI_PROVIDER=groq
  GOOGLE_AI_API_KEY: ""          # if AI_PROVIDER=google

  # ── Observability ────────────────────────────────────────
  # OTEL_EXPORTER_OTLP_ENDPOINT: "" # e.g. https://otel.example.com/v1/traces
  # UPTIME_MONITOR_URL: ""          # Dashboard URL of your uptime monitor (reference only)
  # SLACK_ALERT_WEBHOOK: ""         # Slack incoming webhook URL
  # ALERT_EMAIL_TO: ""              # Comma-separated admin emails for alerts

  # ── Optional OAuth (leave blank to use credentials only) ──
  GITHUB_CLIENT_ID: ""
  GITHUB_CLIENT_SECRET: ""
  GOOGLE_CLIENT_ID: ""
  GOOGLE_CLIENT_SECRET: ""
