{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".."
  },
  "include": [
    "src/**/*",
    "../lib/db/schema.ts",
    "../lib/queue/types.ts",
    "../lib/queue/client.ts",
    "../lib/queue/enqueue-scan.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
