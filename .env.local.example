# Copy this to .env.local and fill in the values.
# Run: cp .env.local.example .env.local

# ── Auth ──────────────────────────────────────────────────────────────────────
# For local dev: AUTH_PROVIDER=mock skips all auth (auto-logged in)
AUTH_PROVIDER=mock

# For production with Microsoft Entra ID:
# AUTH_PROVIDER=authjs
# AUTH_SECRET=                     # openssl rand -base64 32
# AUTH_ENTRA_ID_ID=                # Application (client) ID from Azure portal
# AUTH_ENTRA_ID_SECRET=            # Client secret value
# AUTH_ENTRA_ID_ISSUER=            # https://login.microsoftonline.com/<tenant-id>/v2.0

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose (default):
DATABASE_URL=postgresql://postgres:root@localhost:5432/saleboom_seo

# ── Queue ─────────────────────────────────────────────────────────────────────
QUEUE_PROVIDER=bullmq
REDIS_URL=redis://localhost:6379

# ── Crawl ─────────────────────────────────────────────────────────────────────
CRAWL_PROVIDER=firecrawl
FIRECRAWL_API_KEY=                 # From firecrawl.dev (cloud) or any string (self-hosted)
# FIRECRAWL_API_URL=http://localhost:3002   # Uncomment for self-hosted Firecrawl

# ── AI ────────────────────────────────────────────────────────────────────────
# For local dev: AI_PROVIDER=mock returns stub responses
AI_PROVIDER=mock

# For production with Azure OpenAI:
# AI_PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=           # https://<resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=         # e.g. gpt-4o

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_PROVIDER=console               # console (dev) | pino (prod)
# LOG_LEVEL=info                   # debug | info | warn | error
# LOG_FILE=                        # Set per-process in npm scripts (see package.json)

# ── Observability ─────────────────────────────────────────────────────────────
# SENTRY_DSN=                      # From sentry.io project settings
# NEXT_PUBLIC_SENTRY_DSN=          # Same value — exposed to browser for client errors

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
