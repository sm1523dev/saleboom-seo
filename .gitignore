# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local dev artifacts (root-level screenshots from browser testing)
/*.png
/*.jpg
/*.jpeg
dump.rdb
logs/

# env files — local secrets never committed, example template always committed
.env
.env.local
.env.*.local
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code
.claude/

# agent skills & tooling (local dev only)
.agents/
.mcp.json
.playwright-mcp/
.prettierignore
.prettierrc
skills-lock.json
session-report-*.html
